{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Solution",
            "command": "godot-mono",
            "args": [
                "--build-solutions",
                "--quit",
                "--headless",
                "${workspaceFolder}/project.godot",
            ],
            "type": "shell",
            // "args": [],
            // "problemMatcher": [
            //     "$tsc"
            // ],
            "presentation": {
                "reveal": "always"
            },
            "group": "build",
            "windows": {
                "command": "${env:USERPROFILE}\\Downloads\\Godot_v4.6-stable_mono_win64\\Godot_v4.6-stable_mono_win64.exe"
            },
        }
    ]
}
